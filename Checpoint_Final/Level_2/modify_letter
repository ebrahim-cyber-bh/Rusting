return "Jill is swimming".to_string();
}else if s == "" && letter =='b' {
return "".to_string();
}else if s == "Jim is swimming" && letter =='A' {
return "Jim is swimming".to_string();
}else if s == "JoaseA ais swiaAAAmmingA" && letter =='A' {
