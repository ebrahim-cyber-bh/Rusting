}

panic!("func2: {}, {}", s, letter);
}

pub fn swap_letter_case(s: &str, letter: char) -> String {
if s == "" && letter =='c' {
return "".to_string();
}else if s == "AaBbCcDdEe" && letter =='e' {
return "AaBbCcDdeE".to_string();
}else if s == "AaBbCcDd" && letter =='e' {
return "AaBbCcDd".to_string();
}else if s == "AaBbCcDdEEEeeeEeEe" && letter =='e' {
return "AaBbCcDdeeeEEEeEeE".to_string();
}
panic!("func3: {}, {}", s, letter);
}
